#!/bin/bash

set -euo pipefail

repo_root="$(cd "$(dirname "$0")/../.." && pwd)"
jepsen_dir="$repo_root/jepsen"

default_workloads=(
  append
  append-cas
  bank
  fencing
  giant-values
  grant
  identity-upsert
  index-consistency
  internal
  register
  rejoin-bootstrap
  tx-fn-register
)

known_workloads=(
  append
  append-cas
  bank
  degraded-rejoin
  fencing
  fencing-retry
  giant-values
  grant
  identity-upsert
  index-consistency
  internal
  membership-drift
  membership-drift-live
  rejoin-bootstrap
  register
  snapshot-checksum-rejoin
  snapshot-copy-corruption-rejoin
  snapshot-db-identity-rejoin
  snapshot-manifest-corruption-rejoin
  tx-fn-register
  udf-readiness
)

usage() {
  cat <<'EOF'
Usage: script/jepsen/quorum-workloads [workload ...] [--all-workloads] [-- extra-jepsen-args]

Runs the real Jepsen quorum-loss nemesis against the selected workloads.

Examples:
  script/jepsen/quorum-workloads
  script/jepsen/quorum-workloads append bank
  script/jepsen/quorum-workloads --all-workloads
  script/jepsen/quorum-workloads append bank -- --time-limit 15 --rate 10

Defaults:
  nemesis: quorum-loss
  workloads: append, append-cas, bank, fencing, giant-values, grant,
             identity-upsert, index-consistency, internal, register,
             rejoin-bootstrap, tx-fn-register
  control backend: sofa-jraft
  nodes: n1,n2,n3
  key count: 4
  rate/time-limit: 6/5 for most workloads
  fencing rate/time-limit: 1/2
  admission rate/time-limit: 1/20 for fencing-retry, membership-drift,
                             membership-drift-live, udf-readiness
  snapshot/rejoin rate/time-limit: 5/30 for degraded-rejoin and snapshot
                                   corruption/identity recovery workloads
  rejoin-bootstrap rate/time-limit: 4/8

Notes:
  --all-workloads runs every standard local workload except witness-topology,
  which needs an explicit 2-data-node/3-control-node topology.

Environment overrides:
  DTLV_JEPSEN_QUORUM_KEY_COUNT
  DTLV_JEPSEN_QUORUM_RATE
  DTLV_JEPSEN_QUORUM_TIME_LIMIT
  DTLV_JEPSEN_QUORUM_FENCING_RATE
  DTLV_JEPSEN_QUORUM_FENCING_TIME_LIMIT
  DTLV_JEPSEN_QUORUM_ADMISSION_RATE
  DTLV_JEPSEN_QUORUM_ADMISSION_TIME_LIMIT
  DTLV_JEPSEN_QUORUM_RECOVERY_RATE
  DTLV_JEPSEN_QUORUM_RECOVERY_TIME_LIMIT
  DTLV_JEPSEN_QUORUM_REJOIN_RATE
  DTLV_JEPSEN_QUORUM_REJOIN_TIME_LIMIT
  DTLV_JEPSEN_QUORUM_ACCOUNT_BALANCE
  DTLV_JEPSEN_QUORUM_MAX_TRANSFER
  DTLV_JEPSEN_QUORUM_MAX_WRITES_PER_KEY
  DTLV_JEPSEN_QUORUM_MIN_TXN_LENGTH
  DTLV_JEPSEN_QUORUM_MAX_TXN_LENGTH
  DTLV_JEPSEN_SKIP_JAVAC
  DTLV_JEPSEN_PORT_RETRY_COUNT
  DTLV_JEPSEN_PORT_RETRY_DELAY_S
EOF
}

list_workloads() {
  printf '%s\n' "${known_workloads[@]}"
}

known_workload() {
  local candidate="$1"
  local workload
  for workload in "${known_workloads[@]}"; do
    if [[ "$workload" == "$candidate" ]]; then
      return 0
    fi
  done
  return 1
}

latest_results_file() {
  local workload="$1"
  local results_dir="$jepsen_dir/store/${workload} sofa-jraft"
  if [[ ! -d "$results_dir" ]]; then
    return 1
  fi
  find "$results_dir" -mindepth 2 -maxdepth 2 -name results.edn -print 2>/dev/null \
    | sort \
    | tail -n 1
}

print_result_summary() {
  local results_file="$1"
  (
    cd "$repo_root"
    RESULTS_FILE="$results_file" clojure -M -e '
      (let [m (clojure.edn/read-string
                {:default (fn [_ value] value)}
                (slurp (System/getenv "RESULTS_FILE")))
            summary {:valid? (:valid? m)
                     :exceptions (get-in m [:exceptions :valid?])
                     :workload (get-in m [:workload :valid?])}]
        (println (pr-str summary))
        (when-not (true? (:valid? m))
          (System/exit 1)))'
  )
}

run_jepsen() {
  local log_file="$1"
  shift

  local attempt=0
  local run_exit=0

  while true; do
    if [[ "$stream_logs" == "1" ]]; then
      if (
        cd "$jepsen_dir"
        "$@" 2>&1 | tee "$log_file"
      ); then
        return 0
      else
        run_exit=$?
      fi
    else
      if (
        cd "$jepsen_dir"
        "$@" >"$log_file" 2>&1
      ); then
        return 0
      else
        run_exit=$?
      fi
    fi

    if grep -Fq "Operation not permitted" "$log_file"; then
      printf '    port reservation denied by environment: see %s\n' "$log_file" >&2
      return "$run_exit"
    fi

    if ! grep -Fq "Unable to reserve Jepsen server port" "$log_file"; then
      return "$run_exit"
    fi

    if (( attempt >= port_retry_count )); then
      return "$run_exit"
    fi

    attempt=$((attempt + 1))
    printf '    retry: port reservation failed, retrying (%d/%d)\n' \
      "$attempt" \
      "$port_retry_count"
    sleep "$port_retry_delay_s"
  done
}

ensure_java_classes() {
  if [[ "${DTLV_JEPSEN_SKIP_JAVAC:-0}" == "1" ]]; then
    return 0
  fi

  (
    cd "$repo_root"
    lein javac
  )
}

selected_workloads=()
extra_args=()
use_all_workloads=0

while (($#)); do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --list)
      list_workloads
      exit 0
      ;;
    --all-workloads)
      use_all_workloads=1
      shift
      ;;
    --)
      shift
      extra_args=("$@")
      break
      ;;
    *)
      if ! known_workload "$1"; then
        echo "Unknown workload: $1" >&2
        echo >&2
        usage >&2
        exit 2
      fi
      selected_workloads+=("$1")
      shift
      ;;
  esac
done

if [[ "$use_all_workloads" == "1" && ${#selected_workloads[@]} -gt 0 ]]; then
  echo "Cannot combine --all-workloads with explicit workloads" >&2
  exit 2
fi

if [[ "$use_all_workloads" == "1" ]]; then
  selected_workloads=("${known_workloads[@]}")
elif [[ ${#selected_workloads[@]} -eq 0 ]]; then
  selected_workloads=("${default_workloads[@]}")
fi

key_count="${DTLV_JEPSEN_QUORUM_KEY_COUNT:-4}"
rate="${DTLV_JEPSEN_QUORUM_RATE:-6}"
time_limit="${DTLV_JEPSEN_QUORUM_TIME_LIMIT:-5}"
fencing_rate="${DTLV_JEPSEN_QUORUM_FENCING_RATE:-1}"
fencing_time_limit="${DTLV_JEPSEN_QUORUM_FENCING_TIME_LIMIT:-2}"
admission_rate="${DTLV_JEPSEN_QUORUM_ADMISSION_RATE:-1}"
admission_time_limit="${DTLV_JEPSEN_QUORUM_ADMISSION_TIME_LIMIT:-20}"
recovery_rate="${DTLV_JEPSEN_QUORUM_RECOVERY_RATE:-5}"
recovery_time_limit="${DTLV_JEPSEN_QUORUM_RECOVERY_TIME_LIMIT:-30}"
rejoin_rate="${DTLV_JEPSEN_QUORUM_REJOIN_RATE:-4}"
rejoin_time_limit="${DTLV_JEPSEN_QUORUM_REJOIN_TIME_LIMIT:-8}"
account_balance="${DTLV_JEPSEN_QUORUM_ACCOUNT_BALANCE:-100}"
max_transfer="${DTLV_JEPSEN_QUORUM_MAX_TRANSFER:-5}"
max_writes_per_key="${DTLV_JEPSEN_QUORUM_MAX_WRITES_PER_KEY:-8}"
min_txn_length="${DTLV_JEPSEN_QUORUM_MIN_TXN_LENGTH:-1}"
max_txn_length="${DTLV_JEPSEN_QUORUM_MAX_TXN_LENGTH:-1}"

common_args=(
  run
  test
  --no-ssh
  --nodes
  n1,n2,n3
  --control-backend
  sofa-jraft
  --nemesis
  quorum-loss
)

status=0
summaries=()
run_id="$(date +%Y%m%dT%H%M%S)"
log_dir="$repo_root/tmp/jepsen-quorum-workloads/$run_id"
stream_logs="${DTLV_JEPSEN_QUORUM_STREAM_LOGS:-0}"
port_retry_count="${DTLV_JEPSEN_PORT_RETRY_COUNT:-2}"
port_retry_delay_s="${DTLV_JEPSEN_PORT_RETRY_DELAY_S:-1}"

mkdir -p "$log_dir"
ensure_java_classes

for workload in "${selected_workloads[@]}"; do
  workload_rate="$rate"
  workload_time_limit="$time_limit"
  if [[ "$workload" == "fencing" ]]; then
    workload_rate="$fencing_rate"
    workload_time_limit="$fencing_time_limit"
  elif [[ "$workload" == "fencing-retry" || \
          "$workload" == "membership-drift" || \
          "$workload" == "membership-drift-live" || \
          "$workload" == "udf-readiness" ]]; then
    workload_rate="$admission_rate"
    workload_time_limit="$admission_time_limit"
  elif [[ "$workload" == "degraded-rejoin" || \
          "$workload" == "snapshot-checksum-rejoin" || \
          "$workload" == "snapshot-copy-corruption-rejoin" || \
          "$workload" == "snapshot-db-identity-rejoin" || \
          "$workload" == "snapshot-manifest-corruption-rejoin" ]]; then
    workload_rate="$recovery_rate"
    workload_time_limit="$recovery_time_limit"
  elif [[ "$workload" == "rejoin-bootstrap" ]]; then
    workload_rate="$rejoin_rate"
    workload_time_limit="$rejoin_time_limit"
  fi

  run_args=(
    --workload
    "$workload"
    --db-name
    "quorum-loss-$workload"
    --time-limit
    "$workload_time_limit"
    --rate
    "$workload_rate"
    --key-count
    "$key_count"
    --account-balance
    "$account_balance"
    --max-transfer
    "$max_transfer"
    --max-writes-per-key
    "$max_writes_per_key"
    --min-txn-length
    "$min_txn_length"
    --max-txn-length
    "$max_txn_length"
  )

  before_results="$(latest_results_file "$workload" || true)"
  log_file="$log_dir/${workload}.log"

  extra_args_display=""
  if [[ ${#extra_args[@]} -gt 0 ]]; then
    extra_args_display=" ${extra_args[*]}"
  fi

  command=(lein trampoline "${common_args[@]}" "${run_args[@]}")
  if [[ ${#extra_args[@]} -gt 0 ]]; then
    command+=("${extra_args[@]}")
  fi

  printf '==> [%s] lein trampoline %s%s\n' \
    "$workload" \
    "${common_args[*]} ${run_args[*]}" \
    "$extra_args_display"
  printf '    log: %s\n' "$log_file"

  if run_jepsen "$log_file" "${command[@]}"; then
    results_file="$(latest_results_file "$workload" || true)"
    if [[ -n "${results_file:-}" && "$results_file" != "$before_results" ]]; then
      if summary_output="$(print_result_summary "$results_file" 2>&1)"; then
        printf '    status: %s\n' "$summary_output"
        summaries+=("$workload ok $summary_output results=$results_file log=$log_file")
      else
        status=1
        printf '%s\n' "$summary_output"
        summaries+=("$workload invalid results=$results_file log=$log_file")
      fi
    else
      status=1
      printf '    warning: no new results.edn found\n'
      summaries+=("$workload missing-results log=$log_file")
    fi
  else
    run_exit=$?
    results_file="$(latest_results_file "$workload" || true)"
    if [[ -n "${results_file:-}" && "$results_file" != "$before_results" ]]; then
      if summary_output="$(print_result_summary "$results_file" 2>&1)"; then
        printf '    status: %s\n' "$summary_output"
        summaries+=("$workload ok-after-exit $summary_output results=$results_file log=$log_file")
      else
        status=1
        printf '%s\n' "$summary_output"
        summaries+=("$workload invalid results=$results_file log=$log_file")
      fi
    else
      status=1
      printf '    status: command failed (exit %d), see %s\n' "$run_exit" "$log_file"
      summaries+=("$workload command-failed exit=$run_exit log=$log_file")
    fi
  fi
done

printf '\nSummary (%s)\n' "$log_dir"
printf '  %s\n' "${summaries[@]}"

exit "$status"
